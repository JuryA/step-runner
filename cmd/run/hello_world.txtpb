type:steps
  steps: {
    name: "name"
    step: {
      protocol: local
      path: ".."
      path: ".."
      path: "integration_test"
      path: "steps"
      path: "echo"
      filename: "step.yml"
    }
    inputs: {
      key: "echo"
      value: {
        string_value: "world"
      }
    }
  }
  steps: {
    name: "greeting"
    step: {
      protocol: local
      path: ".."
      path: ".."
      path: "integration_test"
      path: "steps"
      path: "echo"
      filename: "step.yml"
    }
    inputs: {
      key: "echo"
      value: {
        string_value: "hello ${{ steps.name.outputs.echo }}"
      }
    }
  }
